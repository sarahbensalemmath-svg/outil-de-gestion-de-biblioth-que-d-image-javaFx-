<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controller">
    <top>
        <HBox spacing="10" style="-fx-padding: 10;">
            <Button text="Choisir une image" onAction="#handleLoadImage"/>
            <ComboBox fx:id="comboFiltres" promptText="Choisir un filtre"/>
            <Button text="Appliquer" onAction="#handleAppliquerFiltre"/>
            <Button text="Réinitialiser" onAction="#handleReinitialiser"/>
        </HBox>
    </top>
    <center>
        <ImageView fx:id="imageView" fitWidth="680" fitHeight="440" preserveRatio="true"/>
    </center>
</BorderPane>